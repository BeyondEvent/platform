{
  "name": "@beyondevent/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build": "tsc --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "node --env-file=../../.env --import tsx/esm src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ./src",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@beyondevent/event-bus": "workspace:*",
    "@beyondevent/metrics": "workspace:*",
    "@beyondevent/runtime": "workspace:*",
    "@beyondevent/shared": "workspace:*",
    "@beyondevent/topology": "workspace:*",
    "@beyondevent/tracing": "workspace:*",
    "@beyondevent/worker-sdk": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "pg": "^8.13.0",
    "bullmq": "^5.26.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "socket.io": "^4.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.27.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "7.0.1-rc",
    "vitest": "^2.1.0"
  }
}
